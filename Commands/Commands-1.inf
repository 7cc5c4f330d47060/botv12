  op:{
    command:(n,c,_UN,uuid)=>{
      cwc("/execute as "+uuid+" run op @s[type=player]")
    },
    perms: 0,
    h: "OPs you"
  },
  console:{
    command:(n,c)=>{
      var args=c.split(" ");
      global.consoleOnly=+(args[1]);
      cwc("Commands can now "+["only be run by console","be run by everyone"][+(!global.consoleOnly)]+".");
    },
    hidden: 1,
    console: 1
  },
  rtp:{
    command:(n,c,_UN,uuid)=>{
      var args=c.split(" ");
      var range=1000000
      if(args[1]){
        range=+(args[1]);
      }
      const x=Math.floor(Math.random()*(range*2)-range);
      const z=Math.floor(Math.random()*(range*2)-range);
      cwc("/setblock ~ 69 ~ command_block{Command:\"/tp "+uuid+` ${x} 100 ${z}",auto:1b} destroy`);
    },
    perms: 0,
    h: "Teleport to a random location, rtp [range] (range defaults to 1000000)"
  },
  cmdblock:{
    command:(n,c)=>{
      var args=c.split(" ");
      global.bot.write("update_command_block",{location:{x:+args[1],y:+args[2],z:+args[3]},command:c.slice(args[1].length+args[2].length+args[3].length+args[4].length+args[5].length+14),mode:+args[4],flags:+args[5]})
    },
    hidden: 1,
    console: 1,
    h: "Set a command block's data and type"
  },
  botinfo:{
    command:(n,c)=>{
      var _time=new Date(process.uptime()*1000)
      var __time=function(time){
        var _fin = [];
        _fin.push(time.getUTCSeconds()+" second"+(time.getUTCSeconds()!==1?"s":""));
        if(time.getUTCMinutes()!==0){
          _fin.push(time.getUTCMinutes()+" minute"+(time.getUTCMinutes()!==1?"s":""));
        }
        if(time.getUTCHours()!==0){
          _fin.push(time.getUTCHours()+" hour"+(time.getUTCHours()!==1?"s":""));
        }
        if(((time.getUTCDate()-1)+" days")!=="0 days"){
          _fin.push((time.getUTCDate()-1)+" day"+((time.getUTCDate()-1)!==1?"s":""));
        }
        if((time.getUTCMonth()-0)!==0){
          _fin.push(time.getUTCMonth()+" month"+((time.getUTCMonth()-0)!==1?"s":""));
        }
        if(((time.getUTCFullYear()-1970)+" years")!=="0 years"){
          _fin.push((time.getUTCFullYear()-1970)+" year"+((time.getUTCFullYear()-1970)!==1?"s":""));
        }
        return _fin.reverse().join(" ");
      }
      cwc("&7Process uptime: &d"+__time(_time))
      var os=require("os");
      cwc("&7System uptime: &d"+__time(new Date(os.uptime()*1000)))
      cwc("&7Username: &d"+os.userInfo().username)
      cwc("&7OS version: &d"+os.type().replace(/\_/g," ")+" "+os.release())
      cwc("&7Current MC server: &d"+(conf.server)+(conf.port?(":"+conf.port):":25565"))
    },
    hidden: 1,
    console: 1,
    h: "Get bot and system information (uptime, OS info, MC server, etc)"
  },
  seen:{
    command:(n,c)=>{
      var args=c.split(" ");
      const arg1=args[1];
      if(!(arg1[8]==="-" && arg1[13]==="-" && arg1[18]==="-" && arg1[23]==="-")){
        args[1] = global.javaUUID("OfflinePlayer:"+arg1);
      }
      if(getSeen(arg1)!==undefined){
        var a = new Date(getSeen(arg1)[0]);
        cwc(arg1+" was last seen on the server at "+getDateAndTime4L(a)+".")
      } else {
        cwc(arg1+" was never on the server.")
      }
    },
    perms: 0,
    hidden: 1,
    console: 1,
    h: "\xa7\x00See when a player was last online"
  },
  lock:{
    command:(n,c)=>{
      cwc("a")
    },
    perms: 0,
    h: "lock"
  },
  unlock:{
    command:(n,c)=>{
      cwc("a")
    },
    perms: 0,
    h: "lock"
  },
  cb:{
    command:(n,c)=>{
      var cb=c.slice(3);
      cwc("/setblock ~ 69 ~ command_block{Command:\""+cb+"\",auto:1b} destroy")
    },
    perms: 0,
    h: "Runs a command in a command block"
  },
  command:{
    command:(n,c,console,uuid)=>{
      if(!console){console=false;}
      const args=c.split(" ")
      if(args.length==1){
        //cwc("Please specify a command to run.")  
        return;
      }
      global.command(n,c.slice(args[0].length+1),console,uuid);
    },
    perms: 0,
    h: "Runs a bot command"
  },
  maestro:{
    command:(n,c,console,uuid)=>{
      var args=c.split(" ");
      if(args[1]=="start"){
        if(!isMaestro){
          _maestro.start();
        } else {
          cwc("Cannot do operation START: maestro is on.")
        }
      } else if(args[1]=="start"){
        if(isMaestro){
          _maestro.run(c.slice(12));
        } else {
          cwc("Cannot do operation RUN: maestro is not on.")
        }
      } else if(args[1]=="stop"){
        if(isMaestro){
          _maestro.stop();
        } else {
          cwc("Cannot do operation STOP: maestro is not on.")
        }
      } else if(args[1]=="build"){
        if(isMaestro){
          var length=17+args[2].length+args[3].length+args[4].length
          _maestro.build(c.slice(length),{x:+args[2],y:+args[3],z:+args[4]});
        } else {
          cwc("Cannot do operation BUILD: maestro is not on.")
        }
      } 
    },
    perms: 0,
    confirm: 1,
    h: "Ripoff maestro"
  }
},
module.exports.cmd=module.exports.command;
module.exports[""]=module.exports.command;
